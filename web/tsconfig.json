{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "../shared"],
  "exclude": ["src/mobile", "src/browser-viewer", "src/screenshot-themes", "src/onboarding", "src/splash", "**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
}
