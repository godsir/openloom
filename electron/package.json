{
  "name": "openloom-electron",
  "version": "0.1.0",
  "main": "main.cjs",
  "scripts": {
    "dev": "node launch.cjs --dev",
    "dev:no-vite": "node launch.cjs --dev --no-vite",
    "start": "node launch.cjs",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.openloom.app",
    "productName": "openLoom",
    "files": [
      "main.js",
      "preload.js",
      "icons/icon.png",
      "../web/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../target/release/loom-server",
        "to": "engine"
      }
    ],
    "win": {
      "target": "msi",
      "icon": "icons/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  }
}
