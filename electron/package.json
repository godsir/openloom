{
  "name": "openloom-electron",
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.openloom.app",
    "productName": "openLoom",
    "files": [
      "main.js",
      "preload.js",
      "../web/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../target/release/openloom",
        "to": "engine"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "msi"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^26.8.1"
  }
}
