{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./out",
    "paths": { "@/*": ["./src/renderer/src/*"] }
  },
  "include": ["src/renderer/src/**/*"]
}
